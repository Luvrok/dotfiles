# A script that generates a rofi menu that uses bluetoothctl to
# connect to bluetooth devices and display status info.
#
# Inspired by networkmanager-dmenu (https://github.com/firecat53/networkmanager-dmenu)
# Thanks to x70b1 (https://github.com/polybar/polybar-scripts/tree/master/polybar-scripts/system-bluetooth-bluetoothctl)
#
# Depends on:
#   Arch repositories: rofi, bluez-utils (contains bluetoothctl), bc

# Constants
divider="---------"
goback="Back"

# Stable notification: replaces the previous one instead of stacking.
# dunst groups/replaces by x-dunst-stack-tag across separate invocations.
notify() {
    # $1 = body, $2 = urgency (normal/critical, default normal), $3 = timeout ms (default 3000)
    notify-send "Bluetooth" "$1" \
        -h string:x-dunst-stack-tag:rofi-bluetooth \
        -h string:x-canonical-private-synchronous:rofi-bluetooth \
        -u "${2:-normal}" \
        -t "${3:-3000}"
}

# Checks if bluetooth controller is powered on
power_on() {
    if bluetoothctl show | grep -q "Powered: yes"; then
        return 0
    else
        return 1
    fi
}

# Toggles power state
toggle_power() {
    if power_on; then
        notify "Выключаю Bluetooth..."
        bluetoothctl power off
        notify "Bluetooth выключен"
        show_menu
    else
        if rfkill list bluetooth | grep -q 'blocked: yes'; then
            notify "Снимаю блокировку rfkill..."
            rfkill unblock bluetooth && sleep 3
        fi
        notify "Включаю Bluetooth..."
        bluetoothctl power on
        notify "Bluetooth включён"
        show_menu
    fi
}

# Checks if controller is scanning for new devices
scan_on() {
    if bluetoothctl show | grep -q "Discovering: yes"; then
        echo "Scan: on"
        return 0
    else
        echo "Scan: off"
        return 1
    fi
}

# Toggles scanning state
toggle_scan() {
    if scan_on; then
        kill $(pgrep -f "bluetoothctl --timeout 5 scan on")
        bluetoothctl scan off
        notify "Поиск устройств остановлен"
        show_menu
    else
        notify "Поиск устройств... (5 сек)"
        bluetoothctl --timeout 5 scan on
        notify "Поиск завершён"
        show_menu
    fi
}

# Checks if controller is able to pair to devices
pairable_on() {
    if bluetoothctl show | grep -q "Pairable: yes"; then
        echo "Pairable: on"
        return 0
    else
        echo "Pairable: off"
        return 1
    fi
}

# Toggles pairable state
toggle_pairable() {
    if pairable_on; then
        bluetoothctl pairable off
        notify "Pairable: выключено"
        show_menu
    else
        bluetoothctl pairable on
        notify "Pairable: включено"
        show_menu
    fi
}

# Checks if controller is discoverable by other devices
discoverable_on() {
    if bluetoothctl show | grep -q "Discoverable: yes"; then
        echo "Discoverable: on"
        return 0
    else
        echo "Discoverable: off"
        return 1
    fi
}

# Toggles discoverable state
toggle_discoverable() {
    if discoverable_on; then
        bluetoothctl discoverable off
        notify "Discoverable: выключено"
        show_menu
    else
        bluetoothctl discoverable on
        notify "Discoverable: включено"
        show_menu
    fi
}

# Checks if a device is connected
device_connected() {
    device_info=$(bluetoothctl info "$1")
    if echo "$device_info" | grep -q "Connected: yes"; then
        return 0
    else
        return 1
    fi
}

# Toggles device connection
toggle_connection() {
    local name
    name=$(bluetoothctl info "$1" | grep "Alias" | cut -d ' ' -f 2-)
    [ -z "$name" ] && name="$1"
    if device_connected "$1"; then
        notify "Отключаю $name..."
        if bluetoothctl disconnect "$1" | grep -q "Successful"; then
            notify "$name отключён"
        else
            notify "Не удалось отключить $name" critical
        fi
        device_menu "$device"
    else
        notify "Подключаю $name..."
        if bluetoothctl connect "$1" | grep -q "Connection successful"; then
            notify "$name подключён"
        else
            notify "Не удалось подключить $name" critical
        fi
        device_menu "$device"
    fi
}

# Checks if a device is paired
device_paired() {
    device_info=$(bluetoothctl info "$1")
    if echo "$device_info" | grep -q "Paired: yes"; then
        echo "Paired: yes"
        return 0
    else
        echo "Paired: no"
        return 1
    fi
}

toggle_paired() {
    if device_paired "$1"; then
        bluetoothctl remove "$1"
        notify "Сопряжение удалено"
        device_menu "$device"
        return
    fi

    notify "Начинаю сопряжение..."

    local mac="$1"

    expect <<EOF
log_user 0
set timeout 45
spawn bluetoothctl
expect -re {Agent registered|#}
send "agent on\r"
send "default-agent\r"
send "pair $mac\r"
set result "timeout"
expect {
    -re {Confirm passkey (\d+)} {
        catch {exec notify-send "Bluetooth" "Подтвердите код на устройстве: \$expect_out(1,string)" -h string:x-dunst-stack-tag:rofi-bluetooth -t 20000 -u critical}
        send "yes\r"
        exp_continue
    }
    -re {\[agent\] Passkey: (\d+)} {
        catch {exec notify-send "Bluetooth" "Введите этот passkey на устройстве и нажмите Enter: \$expect_out(1,string)" -h string:x-dunst-stack-tag:rofi-bluetooth -t 30000 -u critical}
        exp_continue
    }
    -re {\[agent\] PIN code: (\S+)} {
        catch {exec notify-send "Bluetooth" "Введите этот PIN на устройстве: \$expect_out(1,string)" -h string:x-dunst-stack-tag:rofi-bluetooth -t 30000 -u critical}
        exp_continue
    }
    -re {Enter passkey} {
        set code ""
        catch {set code [exec rofi -dmenu -p "Bluetooth passkey" << ""]}
        send "\$code\r"
        exp_continue
    }
    -re {Enter PIN code:} {
        set code ""
        catch {set code [exec rofi -dmenu -p "Bluetooth PIN" << ""]}
        send "\$code\r"
        exp_continue
    }
    -re {Authorize service} {
        send "yes\r"
        exp_continue
    }
    -re {\(yes/no\)} {
        send "yes\r"
        exp_continue
    }
    -re {Pairing successful} { set result "success" }
    -re {Failed to pair}     { set result "failed" }
    -re {not available}      { set result "notfound" }
    timeout                  { set result "timeout" }
}
if {\$result eq "success"} {
    send "trust $mac\r"
    expect -re {trust succeeded|Trusted: yes|#}
    send "connect $mac\r"
    expect {
        -re {Authorize service} { send "yes\r"; exp_continue }
        -re {\(yes/no\)}        { send "yes\r"; exp_continue }
        -re {Connection successful} {}
        -re {Failed to connect}     {}
        timeout {}
    }
    catch {exec notify-send "Bluetooth" "Сопряжение и подключение выполнены" -h string:x-dunst-stack-tag:rofi-bluetooth -t 5000}
} elseif {\$result eq "failed"} {
    catch {exec notify-send "Bluetooth" "Сопряжение не удалось" -h string:x-dunst-stack-tag:rofi-bluetooth -t 5000 -u critical}
} elseif {\$result eq "notfound"} {
    catch {exec notify-send "Bluetooth" "Устройство не найдено (сделайте Scan)" -h string:x-dunst-stack-tag:rofi-bluetooth -t 5000 -u critical}
} else {
    catch {exec notify-send "Bluetooth" "Таймаут сопряжения" -h string:x-dunst-stack-tag:rofi-bluetooth -t 5000 -u critical}
}
send "quit\r"
expect eof
EOF

    device_menu "$device"
}

# Checks if a device is trusted
device_trusted() {
    device_info=$(bluetoothctl info "$1")
    if echo "$device_info" | grep -q "Trusted: yes"; then
        echo "Trusted: yes"
        return 0
    else
        echo "Trusted: no"
        return 1
    fi
}

# Toggles device connection
toggle_trust() {
    if device_trusted "$1"; then
        bluetoothctl untrust "$1"
        notify "Доверие снято"
        device_menu "$device"
    else
        bluetoothctl trust "$1"
        notify "Устройство добавлено в доверенные"
        device_menu "$device"
    fi
}

# Prints a short string with the current bluetooth status
# Useful for status bars like polybar, etc.
print_status() {
    if power_on; then
        printf ''

        paired_devices_cmd="devices Paired"
        # Check if an outdated version of bluetoothctl is used to preserve backwards compatibility
        if (( $(echo "$(bluetoothctl version | cut -d ' ' -f 2) < 5.65" | bc -l) )); then
            paired_devices_cmd="paired-devices"
        fi

        mapfile -t paired_devices < <(bluetoothctl $paired_devices_cmd | grep Device | cut -d ' ' -f 2)
        counter=0

        for device in "${paired_devices[@]}"; do
            if device_connected "$device"; then
                device_alias=$(bluetoothctl info "$device" | grep "Alias" | cut -d ' ' -f 2-)

                if [ $counter -gt 0 ]; then
                    printf ", %s" "$device_alias"
                else
                    printf " %s" "$device_alias"
                fi

                ((counter++))
            fi
        done
        printf "\n"
    else
        echo ""
    fi
}

# A submenu for a specific device that allows connecting, pairing, and trusting
device_menu() {
    device=$1

    # Get device name and mac address
    device_name=$(echo "$device" | cut -d ' ' -f 3-)
    mac=$(echo "$device" | cut -d ' ' -f 2)

    # Build options
    if device_connected "$mac"; then
        connected="Connected: yes"
    else
        connected="Connected: no"
    fi
    paired=$(device_paired "$mac")
    trusted=$(device_trusted "$mac")
    options="$connected\n$paired\n$trusted\n$divider\n$goback\nExit"

    # Open rofi menu, read chosen option
    chosen="$(run_rofi "$device_name" "$options")"

    # Match chosen option to command
    case "$chosen" in
        "" | "$divider")
            echo "No option chosen."
            ;;
        "$connected")
            toggle_connection "$mac"
            ;;
        "$paired")
            toggle_paired "$mac"
            ;;
        "$trusted")
            toggle_trust "$mac"
            ;;
        "$goback")
            show_menu
            ;;
    esac
}

run_rofi() {
    local prompt="$1"
    local items="$2"
    local count lines
    count=$(echo -e "$items" | wc -l)
    lines=$(( count > 10 ? 10 : count ))
    echo -e "$items" | rofi -dmenu $rofi_args -p "$prompt" \
        -theme "$HOME/.config/rofi/rofi-bluetooth.rasi" \
        -theme-str "listview { lines: $lines; }"
}

# Opens a rofi menu with current bluetooth status and options to connect
show_menu() {
    # Get menu options
    if power_on; then
        power="Power: on"

        # Human-readable names of devices, one per line
        # If scan is off, will only list paired devices
        devices=$(bluetoothctl devices | grep Device | cut -d ' ' -f 3-)

        # Get controller flags
        scan=$(scan_on)
        pairable=$(pairable_on)
        discoverable=$(discoverable_on)

        # Options passed to rofi
        options="$power\n$scan\n$pairable\n$discoverable\n$divider\n$devices"
    else
        power="Power: off"
        options="$power\nExit"
    fi

    # Open rofi menu, read chosen option
    chosen="$(run_rofi "$device_name" "$options")"

    # Match chosen option to command
    case "$chosen" in
        "" | "$divider")
            echo "No option chosen."
            ;;
        "$power")
            toggle_power
            ;;
        "$scan")
            toggle_scan
            ;;
        "$discoverable")
            toggle_discoverable
            ;;
        "$pairable")
            toggle_pairable
            ;;
        *)
            device=$(bluetoothctl devices | grep "$chosen")
            # Open a submenu if a device is selected
            if [[ $device ]]; then device_menu "$device"; fi
            ;;
    esac
}

rofi_args="$*"

case "$1" in
    --status)
        print_status
        ;;
    *)
        show_menu
        ;;
esac
