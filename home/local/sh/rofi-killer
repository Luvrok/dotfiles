#!/usr/bin/env bash

sel=$(
    ps -eo pid,pgid,user,pcpu,pmem,cmd --sort=-pcpu --no-headers |
    rofi -dmenu -i -p "kill" -lines 10 \
        -theme "$HOME/.config/rofi/rofi-pass.rasi" \
        -theme-str "window { width: 1280px; }"
) || exit 1

read -r pid pgid _ <<< "$sel"

# kernel and other stuff exlude
[[ "$pgid" =~ ^[1-9][0-9]*$ ]] || exit 1

# dont kill our group of process
(( pgid == $(ps -o pgid= -p $$) )) && exit 1

kill -TERM -- "-$pgid" 2>/dev/null

# SIGKILL fallback, if process still live after 2s
{ sleep 2; kill -0 "$pid" 2>/dev/null && kill -KILL -- "-$pgid" 2>/dev/null; } &
