#!/usr/bin/env bash

set -euo pipefail

DIR="${HOME}/HOME/screen_recordings"
PIDFILE="/tmp/recpid"
MODEFILE="/tmp/recmode"

VAAPI_DEVICE="/dev/dri/renderD128"

# auto - vaapi - nvenc - software
ENCODER_BACKEND="${ENCODER_BACKEND:-auto}"

FRAMERATE=60
OUTPUT_VOLUME="0.35"
MIC_VOLUME="3.0"

ROFI_CMD=(
    rofi
    -dmenu
    -theme "$HOME/.config/rofi/rofi-rec.rasi"
)

# Filled by set_encoder / set_audio
VAAPI_INIT=()
VFILTER=()
VCODEC=()
A_INPUTS=()
A_FILTER=()
MAPS=()
A_CODEC=()

notify() {
    notify-send "Screen recorder" "$1"
}

update_dwmblocks() {
    local signals="1 2"

    if ! command -v pgrep >/dev/null 2>&1 || ! command -v pkill >/dev/null 2>&1; then
        return 0
    fi

    if pgrep -x dwmblocks >/dev/null 2>&1; then
        for signal in $signals; do
            pkill -RTMIN+"$signal" dwmblocks 2>/dev/null || true
        done
    elif pgrep -x dwmblocks-async >/dev/null 2>&1; then
        for signal in $signals; do
            pkill -RTMIN+"$signal" dwmblocks-async 2>/dev/null || true
        done
    fi
}

cleanup_recording_state() {
    rm -f "$PIDFILE" "$MODEFILE"
    update_dwmblocks
}

get_screen_size() {
    xdpyinfo | awk '/dimensions:/ {print $2}'
}

is_recording() {
    [[ -f "$PIDFILE" ]] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null
}

get_mic_source() {
    if command -v pactl >/dev/null 2>&1; then
        pactl get-default-source
    elif command -v wpctl >/dev/null 2>&1; then
        wpctl status | grep -A5 'Settings' | grep -A5 'Audio/Source' | awk '{print $3}'
    else
        printf '%s\n' "default"
    fi
}

get_output_source() {
    if command -v pactl >/dev/null 2>&1; then
        printf '%s.monitor\n' "$(pactl get-default-sink)"
    elif command -v wpctl >/dev/null 2>&1; then
        printf '%s.monitor\n' "$(wpctl status | grep 'Audio/Sink' | awk '{print $3}')"
    else
        printf '%s\n' "default.monitor"
    fi
}

stop_recording() {
    if is_recording; then
        kill -2 "$(cat "$PIDFILE")" 2>/dev/null || true
        cleanup_recording_state
        sleep 1
        notify "Recording ended"
    else
        cleanup_recording_state
        notify "No active recording"
    fi
}

detect_encoder_backend() {
    if [[ "$ENCODER_BACKEND" != "auto" ]]; then
        printf '%s\n' "$ENCODER_BACKEND"
        return
    fi

    # NVIDIA: есть устройство и nvenc собран в ffmpeg
    if [[ -e /dev/nvidia0 ]] || command -v nvidia-smi >/dev/null 2>&1; then
        if ffmpeg -hide_banner -encoders 2>/dev/null | grep -q h264_nvenc; then
            printf '%s\n' "nvenc"
            return
        fi
    fi

    # VAAPI: есть render-нода и vaapi-кодер
    if [[ -e "$VAAPI_DEVICE" ]] && \
       ffmpeg -hide_banner -encoders 2>/dev/null | grep -q h264_vaapi; then
        printf '%s\n' "vaapi"
        return
    fi

    printf '%s\n' "software"
}

# --- selections ------------------------------------------------------------

pick_video_target() {
    printf '%s\n' \
        "fullscreen" \
        "monitor" \
        "window" \
        "area" \
        | "${ROFI_CMD[@]}" -theme-str 'listview { lines: 4; }'
}

pick_quality() {
    printf '%s\n' \
        "game" \
        "normal" \
        "lossless" \
        | "${ROFI_CMD[@]}" -theme-str 'listview { lines: 3; }'
}

pick_framerate() {
    printf '%s\n' \
        "60" \
        "30" \
        | "${ROFI_CMD[@]}" -theme-str 'listview { lines: 2; }'
}

list_monitors() {
    xrandr --listmonitors | tail -n +2 | awk '{print $NF}'
}

monitor_geometry() {
    # WxH+X+Y for the named output (strips the /mm physical-size parts)
    local name="$1"
    xrandr --listmonitors | awk -v n="$name" '$NF==n {print $(NF-1)}' | sed 's#/[0-9]*##g'
}

pick_monitor() {
    list_monitors | "${ROFI_CMD[@]}" -theme-str 'listview { lines: 2; }'
}

get_window_id() {
    if ! command -v xwininfo >/dev/null 2>&1; then
        notify "xwininfo is not installed"
        return 1
    fi
    xwininfo 2>/dev/null | awk '/Window id:/ {print $4; exit}'
}

get_area_geometry() {
    if ! command -v slop >/dev/null 2>&1; then
        notify "slop is not installed"
        return 1
    fi
    slop -f "%x %y %w %h"
}

# --- encoder / audio builders ---------------------------------------------

set_encoder() {
    local quality="$1"
    VAAPI_INIT=()
    VFILTER=()
    VCODEC=()

    local backend
    backend="$(detect_encoder_backend)"

    # lossless всегда софтверный - переносимый, не зависит от GPU
    if [[ "$quality" == "lossless" ]]; then
        VCODEC=(-c:v libx264 -qp 0 -preset ultrafast -pix_fmt yuv444p)
        return
    fi

    case "$backend" in
        nvenc)
            VFILTER=(-vf "format=nv12")
            case "$quality" in
                "game")   VCODEC=(-c:v h264_nvenc -preset p4 -rc constqp -qp 24 -maxrate 30M -bufsize 60M) ;;
                "normal") VCODEC=(-c:v h264_nvenc -preset p4 -rc constqp -qp 18 -maxrate 40M -bufsize 80M) ;;
                *) notify "Unknown quality: $quality"; exit 1 ;;
            esac
            ;;
        vaapi)
            VAAPI_INIT=(-vaapi_device "$VAAPI_DEVICE")
            VFILTER=(-vf "format=nv12,hwupload")
            case "$quality" in
                "game")   VCODEC=(-c:v h264_vaapi -qp 24 -maxrate 30M -bufsize 60M) ;;
                "normal") VCODEC=(-c:v h264_vaapi -qp 18 -maxrate 40M -bufsize 80M) ;;
                *) notify "Unknown quality: $quality"; exit 1 ;;
            esac
            ;;
        software)
            VFILTER=(-vf "format=yuv420p")
            case "$quality" in
                "game")   VCODEC=(-c:v libx264 -preset veryfast -crf 23 -maxrate 30M -bufsize 60M) ;;
                "normal") VCODEC=(-c:v libx264 -preset veryfast -crf 18 -maxrate 40M -bufsize 80M) ;;
                *) notify "Unknown quality: $quality"; exit 1 ;;
            esac
            ;;
        *)
            notify "Unknown encoder backend: $backend"; exit 1 ;;
    esac
}

set_audio() {
    local mode="$1"
    A_INPUTS=()
    A_FILTER=()
    MAPS=(-map 0:v:0)
    A_CODEC=()

    case "$mode" in
        "screen_only")
            ;;
        "screen_mic")
            A_INPUTS=(-f pulse -i "$(get_mic_source)")
            A_FILTER=(-af "pan=stereo|c0=c0|c1=c0,volume=${MIC_VOLUME}")
            MAPS+=(-map 1:a:0)
            A_CODEC=(-c:a aac -b:a 192k)
            ;;
        "screen_output")
            A_INPUTS=(-f pulse -i "$(get_output_source)")
            A_FILTER=(-af "volume=${OUTPUT_VOLUME}")
            MAPS+=(-map 1:a:0)
            A_CODEC=(-c:a aac -b:a 192k)
            ;;
        "screen_mic_output")
            A_INPUTS=(-f pulse -i "$(get_output_source)" -f pulse -i "$(get_mic_source)")
            A_FILTER=(-filter_complex "[1:a]volume=${OUTPUT_VOLUME}[sys];[2:a]pan=stereo|c0=c0|c1=c0,volume=${MIC_VOLUME}[mic];[sys][mic]amix=inputs=2:normalize=0[aout]")
            MAPS+=(-map "[aout]")
            A_CODEC=(-c:a aac -b:a 192k)
            ;;
        *)
            notify "Unknown mode: $mode"
            exit 1
            ;;
    esac
}

watch_recording() {
    local recpid="$1"
    (
        while kill -0 "$recpid" 2>/dev/null; do
            sleep 1
        done
        if [[ -f "$PIDFILE" ]] && [[ "$(cat "$PIDFILE" 2>/dev/null)" = "$recpid" ]]; then
            cleanup_recording_state
            sleep 1
            notify "Recording ended"
        fi
    ) >/dev/null 2>&1 &
}

build_video_args() {
    # echoes nothing; sets video_args via nameref
    local -n out="$1"
    local target="$2"
    local screen_size wid X Y W H area_geometry mon geo

    case "$target" in
        "fullscreen")
            screen_size="$(get_screen_size)"
            out=(-f x11grab -video_size "$screen_size" -framerate "$FRAMERATE" -i :0.0)
            ;;
        "monitor")
            mon="$(pick_monitor || true)"
            [[ -n "$mon" ]] || exit 0
            geo="$(monitor_geometry "$mon")"
            [[ -n "$geo" ]] || { notify "Monitor geometry not found"; exit 1; }
            read -r W H X Y <<< "$(printf '%s\n' "$geo" | sed 's/[x+]/ /g')"
            out=(-f x11grab -video_size "${W}x${H}" -framerate "$FRAMERATE" -i ":0.0+${X},${Y}")
            ;;
        "window")
            wid="$(get_window_id || true)"
            [[ -n "$wid" ]] || exit 0
            out=(-f x11grab -framerate "$FRAMERATE" -window_id "$wid" -i :0.0)
            ;;
        "area")
            area_geometry="$(get_area_geometry || true)"
            [[ -n "$area_geometry" ]] || exit 0
            read -r X Y W H <<< "$area_geometry"
            [[ -n "${W:-}" && -n "${H:-}" ]] || exit 0
            out=(-f x11grab -video_size "${W}x${H}" -framerate "$FRAMERATE" -i ":0.0+${X},${Y}")
            ;;
        *)
            notify "Unknown target: $target"
            exit 1
            ;;
    esac
}

start_recording() {
    local mode="$1"
    local target="$2"
    local quality="$3"
    local outfile recpid
    local video_args=()

    if is_recording; then
        notify "Recording is already running"
        exit 0
    fi

    mkdir -p "$DIR"
    outfile="${DIR}/recording_$(date '+%Y-%m-%d_%H-%M-%S').mkv"

    set_encoder "$quality"
    set_audio "$mode"
    build_video_args video_args "$target"

    ffmpeg "${VAAPI_INIT[@]}" \
        "${video_args[@]}" \
        "${A_INPUTS[@]}" \
        "${A_FILTER[@]}" \
        "${MAPS[@]}" \
        "${VFILTER[@]}" \
        "${VCODEC[@]}" \
        "${A_CODEC[@]}" \
        "$outfile" \
        >/dev/null 2>&1 &
    recpid=$!

    echo "$recpid" > "$PIDFILE"
    echo "${mode}:${target}:${quality}:${FRAMERATE}" > "$MODEFILE"
    update_dwmblocks
    watch_recording "$recpid"
    notify "Recording started: $outfile"
}

menu() {
    printf '%s\n' \
        "Screen + mic + output" \
        "Screen only" \
        "Screen + mic" \
        "Screen + output" \
        | "${ROFI_CMD[@]}"
}

main() {
    local choice mode quality fps target

    if [[ "${1:-}" = "stop" ]]; then
        stop_recording
        exit 0
    fi

    choice="$(menu || true)"
    [[ -n "$choice" ]] || exit 0
    case "$choice" in
        "Screen + mic + output") mode="screen_mic_output" ;;
        "Screen only")           mode="screen_only" ;;
        "Screen + mic")          mode="screen_mic" ;;
        "Screen + output")       mode="screen_output" ;;
        *) exit 0 ;;
    esac

    quality="$(pick_quality || true)"
    [[ -n "$quality" ]] || exit 0

    fps="$(pick_framerate || true)"
    [[ -n "$fps" ]] || exit 0
    FRAMERATE="$fps"

    target="$(pick_video_target || true)"
    [[ -n "$target" ]] || exit 0

    start_recording "$mode" "$target" "$quality"
}

main "$@"
