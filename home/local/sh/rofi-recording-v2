#!/bin/sh
set -eu

DIR=${DIR:-"$HOME/HOME/screen_recordings"}
PIDFILE=${PIDFILE:-/tmp/recpid}
MODEFILE=${MODEFILE:-/tmp/recmode}
FRAMERATE=${FRAMERATE:-30}
CRF=${CRF:-18}
PRESET=${PRESET:-veryfast}
OUTPUT_VOLUME=${OUTPUT_VOLUME:-0.35}
MIC_VOLUME=${MIC_VOLUME:-3.0}
DISPLAY_NAME=${DISPLAY:-:0.0}

VIDEO_BACKEND=${VIDEO_BACKEND:-auto}
NVENC_PRESET=${NVENC_PRESET:-p5}
NVENC_CQ=${NVENC_CQ:-23}
VAAPI_QP=${VAAPI_QP:-20}

ROFI_THEME=${ROFI_THEME:-"$HOME/.config/rofi/rofi-rec.rasi"}

notify() {
    if command -v notify-send >/dev/null 2>&1; then
        notify-send "Screen recorder" "$1"
    fi
}

rofi_menu() {
    rofi -dmenu -theme "$ROFI_THEME" "$@"
}

update_dwmblocks() {
    signals="1 2"

    if ! command -v pgrep >/dev/null 2>&1 || ! command -v pkill >/dev/null 2>&1; then
        return 0
    fi

    if pgrep -x dwmblocks >/dev/null 2>&1; then
        for signal in $signals; do
            pkill -RTMIN+"$signal" dwmblocks 2>/dev/null || true
        done
    elif pgrep -x dwmblocks-async >/dev/null 2>&1; then
        for signal in $signals; do
            pkill -RTMIN+"$signal" dwmblocks-async 2>/dev/null || true
        done
    fi
}

cleanup_recording_state() {
    rm -f "$PIDFILE" "$MODEFILE"
    update_dwmblocks
}

get_screen_size() {
    xdpyinfo | awk '/dimensions:/ { print $2; exit }'
}

is_recording() {
    if [ ! -f "$PIDFILE" ]; then
        return 1
    fi

    pid=$(cat "$PIDFILE" 2>/dev/null || printf '')
    [ -n "$pid" ] || return 1
    kill -0 "$pid" 2>/dev/null
}

get_mic_source() {
    if command -v pactl >/dev/null 2>&1; then
        pactl get-default-source
    elif command -v wpctl >/dev/null 2>&1; then
        wpctl status 2>/dev/null | awk '
            /Audio\/Source/ { section = "src"; next }
            /Audio\/Sink/   { section = "" }
            section == "src" && /\*/ { print $3; exit }
        '
    else
        printf '%s\n' "default"
    fi
}

get_output_source() {
    if command -v pactl >/dev/null 2>&1; then
        printf '%s.monitor\n' "$(pactl get-default-sink)"
    elif command -v wpctl >/dev/null 2>&1; then
        sink=$(wpctl status 2>/dev/null | awk '
            /Audio\/Sink/   { section = "sink"; next }
            /Audio\/Source/ { section = "" }
            section == "sink" && /\*/ { print $3; exit }
        ')
        if [ -n "$sink" ]; then
            printf '%s.monitor\n' "$sink"
        else
            printf '%s\n' "default.monitor"
        fi
    else
        printf '%s\n' "default.monitor"
    fi
}

detect_backend() {
    case "$VIDEO_BACKEND" in
        nvenc|vaapi|x264)
            printf '%s\n' "$VIDEO_BACKEND"
            return 0
            ;;
        auto)
            ;;
        *)
            notify "Unknown VIDEO_BACKEND: $VIDEO_BACKEND"
            return 1
            ;;
    esac

    if command -v nvidia-smi >/dev/null 2>&1 \
        && ffmpeg -hide_banner -encoders 2>/dev/null | grep -q 'h264_nvenc'; then
        printf '%s\n' "nvenc"
        return 0
    fi

    if [ -e /dev/dri/renderD128 ] \
        && ffmpeg -hide_banner -encoders 2>/dev/null | grep -q 'h264_vaapi'; then
        printf '%s\n' "vaapi"
        return 0
    fi

    printf '%s\n' "x264"
}

stop_recording() {
    if is_recording; then
        kill -INT "$(cat "$PIDFILE")" 2>/dev/null || true
        cleanup_recording_state
        sleep 1
        notify "Recording ended"
    else
        cleanup_recording_state
        notify "No active recording"
    fi
}

pick_video_target() {
    printf '%s\n' \
        "fullscreen" \
        "window" \
        "area" \
        | rofi_menu -theme-str 'listview { lines: 3; }'
}

get_window_id() {
    if ! command -v xwininfo >/dev/null 2>&1; then
        notify "xwininfo is not installed"
        return 1
    fi

    xwininfo 2>/dev/null | awk '/Window id:/ { print $4; exit }'
}

get_area_geometry() {
    if ! command -v slop >/dev/null 2>&1; then
        notify "slop is not installed"
        return 1
    fi

    slop -f "%x %y %w %h"
}

watch_recording() {
    recpid=$1

    (
        while kill -0 "$recpid" 2>/dev/null; do
            sleep 1
        done

        if [ -f "$PIDFILE" ] && [ "$(cat "$PIDFILE" 2>/dev/null)" = "$recpid" ]; then
            cleanup_recording_state
            sleep 1
            notify "Recording ended"
        fi
    ) >/dev/null 2>&1 &
}

run_ffmpeg() {
    backend=$1
    mode=$2
    outfile=$3
    shift 3

    case "$backend:$mode" in
        nvenc:screen_only)
            ffmpeg "$@" \
                -vf format=nv12 \
                -c:v h264_nvenc -preset "$NVENC_PRESET" -rc vbr -cq "$NVENC_CQ" -b:v 0 \
                -maxrate 25M -bufsize 50M \
                "$outfile" \
                >/dev/null 2>&1 &
            ;;
        nvenc:screen_mic)
            ffmpeg "$@" \
                -f pulse -i "$(get_mic_source)" \
                -map 0:v:0 -map 1:a:0 \
                -af "pan=stereo|c0=c0|c1=c0,volume=${MIC_VOLUME}" \
                -vf format=nv12 \
                -c:v h264_nvenc -preset "$NVENC_PRESET" -rc vbr -cq "$NVENC_CQ" -b:v 0 \
                -maxrate 25M -bufsize 50M \
                -c:a aac -b:a 192k \
                "$outfile" \
                >/dev/null 2>&1 &
            ;;
        nvenc:screen_output)
            ffmpeg "$@" \
                -f pulse -i "$(get_output_source)" \
                -map 0:v:0 -map 1:a:0 \
                -af "volume=${OUTPUT_VOLUME}" \
                -vf format=nv12 \
                -c:v h264_nvenc -preset "$NVENC_PRESET" -rc vbr -cq "$NVENC_CQ" -b:v 0 \
                -maxrate 25M -bufsize 50M \
                -c:a aac -b:a 192k \
                "$outfile" \
                >/dev/null 2>&1 &
            ;;
        nvenc:screen_mic_output)
            ffmpeg "$@" \
                -f pulse -i "$(get_output_source)" \
                -f pulse -i "$(get_mic_source)" \
                -filter_complex "[1:a]volume=${OUTPUT_VOLUME}[sys];[2:a]pan=stereo|c0=c0|c1=c0,volume=${MIC_VOLUME}[mic];[sys][mic]amix=inputs=2:normalize=0[aout]" \
                -map 0:v:0 -map "[aout]" \
                -vf format=nv12 \
                -c:v h264_nvenc -preset "$NVENC_PRESET" -rc vbr -cq "$NVENC_CQ" -b:v 0 \
                -maxrate 25M -bufsize 50M \
                -c:a aac -b:a 192k \
                "$outfile" \
                >/dev/null 2>&1 &
            ;;
        vaapi:screen_only)
            ffmpeg -vaapi_device /dev/dri/renderD128 "$@" \
                -vf 'format=nv12,hwupload' \
                -c:v h264_vaapi -qp "$VAAPI_QP" \
                -maxrate 25M -bufsize 50M \
                "$outfile" \
                >/dev/null 2>&1 &
            ;;
        vaapi:screen_mic)
            ffmpeg -vaapi_device /dev/dri/renderD128 "$@" \
                -f pulse -i "$(get_mic_source)" \
                -map 0:v:0 -map 1:a:0 \
                -af "pan=stereo|c0=c0|c1=c0,volume=${MIC_VOLUME}" \
                -vf 'format=nv12,hwupload' \
                -c:v h264_vaapi -qp "$VAAPI_QP" \
                -maxrate 25M -bufsize 50M \
                -c:a aac -b:a 192k \
                "$outfile" \
                >/dev/null 2>&1 &
            ;;
        vaapi:screen_output)
            ffmpeg -vaapi_device /dev/dri/renderD128 "$@" \
                -f pulse -i "$(get_output_source)" \
                -map 0:v:0 -map 1:a:0 \
                -af "volume=${OUTPUT_VOLUME}" \
                -vf 'format=nv12,hwupload' \
                -c:v h264_vaapi -qp "$VAAPI_QP" \
                -maxrate 25M -bufsize 50M \
                -c:a aac -b:a 192k \
                "$outfile" \
                >/dev/null 2>&1 &
            ;;
        vaapi:screen_mic_output)
            ffmpeg -vaapi_device /dev/dri/renderD128 "$@" \
                -f pulse -i "$(get_output_source)" \
                -f pulse -i "$(get_mic_source)" \
                -filter_complex "[1:a]volume=${OUTPUT_VOLUME}[sys];[2:a]pan=stereo|c0=c0|c1=c0,volume=${MIC_VOLUME}[mic];[sys][mic]amix=inputs=2:normalize=0[aout]" \
                -map 0:v:0 -map "[aout]" \
                -vf 'format=nv12,hwupload' \
                -c:v h264_vaapi -qp "$VAAPI_QP" \
                -maxrate 25M -bufsize 50M \
                -c:a aac -b:a 192k \
                "$outfile" \
                >/dev/null 2>&1 &
            ;;
        x264:screen_only)
            ffmpeg "$@" \
                -c:v libx264 -preset "$PRESET" -crf "$CRF" \
                "$outfile" \
                >/dev/null 2>&1 &
            ;;
        x264:screen_mic)
            ffmpeg "$@" \
                -f pulse -i "$(get_mic_source)" \
                -map 0:v:0 -map 1:a:0 \
                -af "pan=stereo|c0=c0|c1=c0,volume=${MIC_VOLUME}" \
                -c:v libx264 -preset "$PRESET" -crf "$CRF" \
                -c:a aac -b:a 192k \
                "$outfile" \
                >/dev/null 2>&1 &
            ;;
        x264:screen_output)
            ffmpeg "$@" \
                -f pulse -i "$(get_output_source)" \
                -map 0:v:0 -map 1:a:0 \
                -af "volume=${OUTPUT_VOLUME}" \
                -c:v libx264 -preset "$PRESET" -crf "$CRF" \
                -c:a aac -b:a 192k \
                "$outfile" \
                >/dev/null 2>&1 &
            ;;
        x264:screen_mic_output)
            ffmpeg "$@" \
                -f pulse -i "$(get_output_source)" \
                -f pulse -i "$(get_mic_source)" \
                -filter_complex "[1:a]volume=${OUTPUT_VOLUME}[sys];[2:a]pan=stereo|c0=c0|c1=c0,volume=${MIC_VOLUME}[mic];[sys][mic]amix=inputs=2:normalize=0[aout]" \
                -map 0:v:0 -map "[aout]" \
                -c:v libx264 -preset "$PRESET" -crf "$CRF" \
                -c:a aac -b:a 192k \
                "$outfile" \
                >/dev/null 2>&1 &
            ;;
        *)
            notify "Unsupported backend/mode: $backend / $mode"
            return 1
            ;;
    esac

    printf '%s\n' "$!"
}

start_recording() {
    mode=$1
    target=$2
    screen_size=$(get_screen_size)
    backend=$(detect_backend)
    outfile="${DIR}/recording_$(date '+%Y-%m-%d_%H-%M-%S').mkv"

    mkdir -p "$DIR"

    if is_recording; then
        notify "Recording is already running"
        exit 0
    fi

    case "$target" in
        fullscreen)
            set -- -f x11grab -video_size "$screen_size" -framerate "$FRAMERATE" -i "$DISPLAY_NAME"
            ;;
        window)
            wid=$(get_window_id || true)
            [ -n "$wid" ] || exit 0
            set -- -f x11grab -framerate "$FRAMERATE" -window_id "$wid" -i "$DISPLAY_NAME"
            ;;
        area)
            area_geometry=$(get_area_geometry || true)
            [ -n "$area_geometry" ] || exit 0
            set -- $area_geometry
            X=$1
            Y=$2
            W=$3
            H=$4
            [ -n "$W" ] && [ -n "$H" ] || exit 0
            set -- -f x11grab -video_size "${W}x${H}" -framerate "$FRAMERATE" -i "${DISPLAY_NAME}+${X},${Y}"
            ;;
        *)
            notify "Unknown target: $target"
            exit 1
            ;;
    esac

    recpid=$(run_ffmpeg "$backend" "$mode" "$outfile" "$@")

    echo "$recpid" > "$PIDFILE"
    echo "${mode}:${target}:${backend}" > "$MODEFILE"
    update_dwmblocks
    watch_recording "$recpid"
    notify "Recording started [$backend]: $outfile"
}

menu() {
    if is_recording; then
        printf '%s\n' \
            "Stop recording" \
            | rofi_menu -theme-str 'listview { lines: 1; }'
    else
        printf '%s\n' \
            "Screen + mic + output" \
            "Screen only" \
            "Screen + mic" \
            "Screen + output" \
            | rofi_menu -theme-str 'listview { lines: 4; }'
    fi
}

main() {
    if [ "${1:-}" = "stop" ]; then
        stop_recording
        exit 0
    fi

    choice=$(menu || true)
    [ -n "$choice" ] || exit 0

    if [ "$choice" = "Stop recording" ]; then
        stop_recording
        exit 0
    fi

    target=$(pick_video_target || true)
    [ -n "$target" ] || exit 0

    case "$choice" in
        "Screen + mic + output") start_recording "screen_mic_output" "$target" ;;
        "Screen only") start_recording "screen_only" "$target" ;;
        "Screen + mic") start_recording "screen_mic" "$target" ;;
        "Screen + output") start_recording "screen_output" "$target" ;;
    esac
}

main "$@"
